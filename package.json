{
	"name": "bibo-webapp",
	"private": true,
	"version": "0.1.0",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:tauri": "cross-env BUILD_TARGET=tauri vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync && npm run paraglide:compile && husky",
		"precommit": "lint-staged",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "^5.1.1",
		"@commitlint/cli": "^21.0.2",
		"@commitlint/config-conventional": "^21.0.2",
		"@eslint/compat": "^2.0.3",
		"@eslint/js": "^10.0.1",
		"@inlang/paraglide-js": "^2.10.0",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.3.4",
		"@storybook/addon-docs": "^10.3.4",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.3.4",
		"@storybook/sveltekit": "^10.3.4",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@total-typescript/ts-reset": "^0.6.1",
		"@types/node": "^24",
		"@types/pikaday": "^1.7.10",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"cross-env": "^10.1.0",
		"daisyui": "^5.5.19",
		"eslint": "^10.0.3",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-prettier": "^5.5.6",
		"eslint-plugin-storybook": "^10.3.4",
		"eslint-plugin-svelte": "^3.15.2",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"storybook": "^10.3.4",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0",
		"vite": "^7.3.1",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@tauri-apps/api": "^2.11.0",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"cally": "^0.9.2"
	}
}
